# Copiar a .env.local para desarrollo local. Ver HANDOFF.md para más detalle
# de cada variable.

POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/playbook
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Resend (magic links de lectores)
RESEND_API_KEY=
EMAIL_FROM="Playbook <onboarding@resend.dev>"

# Vercel Blob (subida de imágenes en el editor)
BLOB_READ_WRITE_TOKEN=

# Webhook de Make.com (api/update-articles)
PLAYBOOK_SECRET=

# GA4 Data API (lectura de pageviews para el módulo "Más leídas" de portada,
# lib/ga4.ts) — credencial de cuenta de servicio, separada del Measurement ID
# de GA4 del lado del cliente (que este sitio todavía no tiene). El service
# account necesita rol Viewer en la propiedad de GA4, además de tener
# habilitada la Analytics Data API en su proyecto de Google Cloud.
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_SERVICE_ACCOUNT_PRIVATE_KEY=

# Vercel Web Analytics API (lib/vercel-analytics.ts, panel de analítica del
# admin — Fase 4). VERCEL_PROJECT_ID normalmente la inyecta Vercel solo como
# System Environment Variable; TEAM_ID/TEAM_SLUG solo hacen falta si el
# proyecto pertenece a un equipo, no a una cuenta personal.
VERCEL_ANALYTICS_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=

# Solo para scripts/seed-editors.ts — mismo formato que el sitio legado
# (usuario:pass,usuario:pass). No se usa en runtime, solo en el seed único.
ADMIN_USERS=
